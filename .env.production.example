# Переменные Postgres для docker-compose.prod.yml (Фаза D2). Скопировать на
# сервере (или для локальной проверки) в реальный файл `.env.production`
# рядом с docker-compose.prod.yml и заполнить реальным паролем. Не
# коммитить файл с реальными значениями — только этот *.example.
#
# Те же имена переменных, что в chef-assistant/.env.example (дев-стек), но
# отдельный файл: docker-compose.yml (дев) и docker-compose.prod.yml лежат в
# одном каталоге и оба по умолчанию подхватили бы один и тот же `.env`, если
# бы имя файла совпадало — держим прод-конфигурацию физически отдельно от
# дев-секретов.
#
# ВАЖНО: значения здесь должны совпадать с DATABASE_URL в
# backend/.env.production (хост "postgres", тот же user/pass/db) — это два
# независимых файла, читаемых разными сервисами (postgres и backend), синхронизация ручная.
POSTGRES_USER=chef
POSTGRES_PASSWORD=<заполнить реальным паролем на сервере, не коммитить>
POSTGRES_DB=chef
