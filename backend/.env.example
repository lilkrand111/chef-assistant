# Скопируйте в .env и заполните реальными значениями. Не коммитить .env с секретами.

# Строка подключения к Postgres, поднятому через docker-compose.yml в корне репозитория
DATABASE_URL=postgresql://chef:chef@localhost:5432/chef

# Ключ Anthropic API. Используется только на сервере (services/ai/*), фронтенд его не видит.
ANTHROPIC_API_KEY=sk-ant-...

# Модели ИИ по задачам (см. §2 спецификации). Не хардкодить в коде.
AI_MODEL_VISION=claude-sonnet-4-6
AI_MODEL_GENERATION=claude-sonnet-4-6
AI_MODEL_CLASSIFY=claude-haiku-4-5

# Идентификатор неявного пользователя (см. §9, аутентификации в v1 нет)
DEFAULT_USER_ID=default

# Порт, на котором слушает Fastify
PORT=3000
