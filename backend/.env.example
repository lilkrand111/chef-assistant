# Скопируйте в .env и заполните реальными значениями. Не коммитить .env с секретами.

# Строка подключения к Postgres, поднятому через docker-compose.yml в корне репозитория
DATABASE_URL=postgresql://chef:chef@localhost:5432/chef

# Доступ к ИИ через OpenAI-совместимый шлюз (§2, §10 спецификации). И шлюз, и
# ключ читаются только в services/ai/client.ts — фронтенд их не видит.
# Все три задачи сейчас идут через Google Gemini (OpenAI-совместимый
# эндпоинт), ключ из Google AI Studio — лимит запросов/день на аккаунте
# ОБЩИЙ на VISION+GENERATION+CLASSIFY.
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=...

# Любую из трёх задач можно перенаправить на ДРУГОГО провайдера через
# AI_<TASK>_BASE_URL/AI_<TASK>_API_KEY (см. client.ts::resolveConfig) — без
# них задача просто использует общий AI_BASE_URL/AI_API_KEY выше. Полезно,
# если у одной задачи закончится лимит/баланс, а у остальных ещё есть —
# правка .env, без изменений кода.

# Модели ИИ по задачам (см. §2 спецификации). Не хардкодить в коде.
AI_MODEL_VISION=gemini-3.5-flash
AI_MODEL_GENERATION=gemini-3.5-flash
AI_MODEL_CLASSIFY=gemini-3.5-flash

# Локальные эмбеддинги для семантического матчинга (§7.1 шаг 4, Фаза 5).
# Считаются оффлайн в этом же процессе (services/ai/embed.ts), БЕЗ обращения к
# AI_BASE_URL — веса модели скачиваются один раз с huggingface.co при первом
# использовании и кешируются локально. Размерность модели (768) зашита в
# миграцию pgvector_embeddings (vector(768)) и в EMBEDDING_DIM — смена модели
# на другую размерность требует новой миграции + пересчёта эмбеддингов (seed).
# LaBSE выбрана вместо более лёгкой MiniLM после реальной проверки (§13 «Фаза
# 5»): MiniLM путала ранжирование ближайшего соседа на редких словах.
AI_EMBED_MODEL=Xenova/LaBSE
# AI_EMBED_MODEL_PATH=   # опционально: путь к локально предзагруженным весам (офлайн-окружение)
# Порог косинусного сходства для семантического совпадения (§7.1 шаг 4).
# Подобран на реальных данных (см. §13 «Фаза 5») — у LaBSE диапазон сходства
# компактнее, чем у MiniLM (несвязанные продукты одного домена могут давать
# ~0.8), поэтому порог выше, чем интуитивно ожидалось бы: 0.90 отсекает
# "разные, но похожие по домену" пары, оставляя явные словоформы/синонимы.
AI_EMBED_MATCH_THRESHOLD=0.90

# Идентификатор неявного пользователя (см. §9, аутентификации в v1 нет)
DEFAULT_USER_ID=default

# Порт, на котором слушает Fastify
PORT=3000
