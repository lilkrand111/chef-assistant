# Пример прод-переменных для backend-контейнера (docker-compose.prod.yml, Фаза D2).
# Скопировать на сервере в env_file (напр. backend/.env.production) и заполнить
# реальными значениями. НЕ КОММИТИТЬ файл с реальными значениями — только этот
# *.example без секретов.

# Хост "postgres" — имя сервиса Postgres в docker-compose.prod.yml (Фаза D2),
# а не localhost, как в дев-окружении (backend/.env.example).
DATABASE_URL=postgresql://<user>:<pass>@postgres:5432/<db>

# Доступ к ИИ через OpenAI-совместимый шлюз (§2, §10 спецификации). И шлюз, и
# ключ читаются только в services/ai/client.ts — фронтенд их не видит
# (предостережение №5 mobile-and-deployment-spec.md §0.1: AI_API_KEY — только
# на сервере, никогда во фронт-бандл).
AI_BASE_URL=https://global.support.by/api/openai
AI_API_KEY=<заполнить реальным ключом на сервере, не коммитить>

# Модели ИИ по задачам (см. §2 спецификации, backend/.env.example) — те же
# значения, что и в деве, если не решено иначе под прод-шлюз/тариф.
AI_MODEL_VISION=gpt-4o-mini
AI_MODEL_GENERATION=gpt-4.1-mini
AI_MODEL_CLASSIFY=gpt-4.1-nano

# Локальные эмбеддинги для семантического матчинга (§7.1 шаг 4, Фаза 5).
# Без изменений относительно дева — размерность (768) зашита в миграцию.
AI_EMBED_MODEL=Xenova/LaBSE
AI_EMBED_MATCH_THRESHOLD=0.90

# Кэш весов модели эмбеддингов (предостережение №2 §0.1) — выбрать ОДИН из
# двух вариантов:
#
# Вариант 1 (по умолчанию, проще для старта) — онлайн-кэш: веса скачиваются
# с huggingface.co при первом вызове embed() и кешируются в volume "models"
# (docker-compose.prod.yml, Фаза D2, точка монтирования /models). Требует
# исходящий доступ к huggingface.co с сервера.
HF_HOME=/models/hf

# Вариант 2 (надёжнее, без сети к hf.co) — офлайн: предзагрузить веса LaBSE
# в volume/образ и указать путь к ним; тогда HF_HOME выше не используется.
# AI_EMBED_MODEL_PATH=/models/labse

# Идентификатор неявного пользователя (см. §9, аутентификации в v1 нет)
DEFAULT_USER_ID=default

# Порт, на котором слушает Fastify внутри контейнера
PORT=3000

# CORS (опционально, по умолчанию НЕ включать). При same-origin деплое за
# nginx (Фаза D2, VITE_API_URL="") origin: true в backend/src/server.ts
# безопасен и достаточен — CORS фактически не участвует, менять server.ts не
# нужно. Если фронт когда-нибудь будет отдаваться с отдельного origin (напр.
# поддомен api.), тогда в server.ts потребуется читать CORS_ORIGIN из env и
# передавать его вместо `true` в app.register(cors, { origin: ... }) —
# это НЕ реализовано в текущей сессии (Фаза D0), только задокументировано
# как возможное расширение на будущее.
# CORS_ORIGIN=https://example.com
