# Адрес бэкенда. Не хардкодить в коде — читать через import.meta.env.VITE_API_URL
#
# Значение ниже (http://localhost:3000) — только для локальной разработки
# (дев-сервер бэкенда). Для прод-сборки (frontend/Dockerfile, Фаза D1;
# docker-compose.prod.yml + nginx, Фаза D2) используется VITE_API_URL=""
# (пустая строка) — фронт и бэк отдаются с одного origin через nginx, все
# запросы идут на относительный /api/..., same-origin, CORS не участвует
# (см. backend/.env.production.example и mobile-and-deployment-spec.md §0.2).
VITE_API_URL=http://localhost:3000
